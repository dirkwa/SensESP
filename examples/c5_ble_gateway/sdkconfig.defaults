# ESP32-C5 BLE gateway — espidf + arduino build.

# Arduino-as-IDF-component
CONFIG_AUTOSTART_ARDUINO=y

# Flash — Waveshare C5 has 16 MB
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# PSRAM — Waveshare C5 NXRX has 8 MB PSRAM (quad mode)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_QUAD=y
CONFIG_SPIRAM_SPEED_80M=y

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="c5_partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="c5_partitions.csv"

# FreeRTOS / main task
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# Bluetooth — Bluedroid with BLE 4.2 legacy scan
CONFIG_BT_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
CONFIG_BT_BLE_ENABLED=y
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y
CONFIG_BT_CLASSIC_ENABLED=n
CONFIG_BT_GATTC_ENABLE=y
CONFIG_BT_GATTS_ENABLE=n
CONFIG_BT_BTU_TASK_STACK_SIZE=8192
CONFIG_BLE_MESH=n

# WiFi/BLE coexistence
CONFIG_SW_COEXIST_ENABLE=y

# Disable ESP Insights (requires HTTPS cert we don't have)
CONFIG_ESP_INSIGHTS_ENABLED=n

# Misc — match SensESP defaults
CONFIG_MBEDTLS_PSK_MODES=y
CONFIG_MBEDTLS_KEY_EXCHANGE_PSK=y
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
